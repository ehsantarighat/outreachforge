# ─── Supabase ───────────────────────────────────────────────────────────────
# Found at: https://supabase.com/dashboard/project/<id>/settings/api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Stripe ─────────────────────────────────────────────────────────────────
# Found at: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Price IDs from your Stripe product catalog
STRIPE_PRICE_SOLO_MONTHLY=
STRIPE_PRICE_SOLO_ANNUAL=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_ANNUAL=

# ─── Anthropic (platform key — shared across all users) ─────────────────────
# Found at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# ─── Google OAuth (Gmail integration) ───────────────────────────────────────
# Found at: https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# Must match authorized redirect URI in Google Cloud Console
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/api/auth/gmail/callback

# ─── Inngest (background jobs) ──────────────────────────────────────────────
# Found at: https://app.inngest.com/settings/keys
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# ─── Research ───────────────────────────────────────────────────────────────
# Tavily API key: https://app.tavily.com
TAVILY_API_KEY=
# Jina Reader base URL (no key required for public usage)
JINA_READER_BASE_URL=https://r.jina.ai

# ─── Transactional email ────────────────────────────────────────────────────
# Resend API key: https://resend.com/api-keys
RESEND_API_KEY=

# ─── Observability ──────────────────────────────────────────────────────────
# Sentry DSN: https://sentry.io → Project Settings → Client Keys
SENTRY_DSN=
# PostHog: https://app.posthog.com → Project Settings
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ─── App-level encryption ───────────────────────────────────────────────────
# 32-byte hex string used for AES-256-GCM encryption of stored secrets.
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=

# ─── App URL ────────────────────────────────────────────────────────────────
# Used for OAuth callbacks and transactional email links
NEXT_PUBLIC_APP_URL=http://localhost:3000
